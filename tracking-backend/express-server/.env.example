# ██████ PROJECT SILHOUETTE — EXPRESS SERVER ENVIRONMENT VARIABLES ██████
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ── CORS ──
ALLOWED_ORIGIN_1=https://blueboop.is-a.dev
ALLOWED_ORIGIN_2=https://nicholas-tritsaris.github.io
PORT=3000

# ── AUTHENTICATION ──
# Username for dashboard login
ADMIN_USERNAME=admin

# SHA-256 hash of the password (lowercase hex, no salt)
# Generate on Linux/Mac: echo -n "yourpassword" | sha256sum
# Generate on Windows:   Get-FileHash -InputStream ([IO.MemoryStream][Text.Encoding]::UTF8.GetBytes("yourpassword")) | Select-Object Hash
ADMIN_PASSWORD_HASH=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8
# ↑ This hash is for "password" — CHANGE IT!

# JWT signing secret — generate a random 64-char string:
# On Linux/Mac: openssl rand -hex 32
# On Windows:   [System.Web.Security.Membership]::GeneratePassword(64,12)
JWT_SECRET=change_this_to_a_random_64_character_secret_string_never_share

# ── NOTE SERVICE SELECTION ──
# Options: google-tasks | evernote | onenote | firestore
NOTE_SERVICE=google-tasks

# ── GOOGLE TASKS API ──
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REFRESH_TOKEN=1//your_refresh_token_string
GOOGLE_TASKLIST_ID=your_tasklist_id

# ── EVERNOTE API ──
EVERNOTE_DEV_TOKEN=S=s1:U=abc:E=12345:C=67890:P=1cd:A=en_oauth:V=2:H=abcdef1234567890
EVERNOTE_NOTEBOOK_GUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EVERNOTE_USE_SANDBOX=false

# ── MICROSOFT ONENOTE (GRAPH) ──
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_SECRET=your_azure_client_secret
MS_REFRESH_TOKEN=your_ms_refresh_token
MS_SECTION_ID=your_onenote_section_id
MS_TENANT_ID=consumers

# ── FIREBASE FIRESTORE (RECOMMENDED — FREE, HIGH LIMITS) ──
# For visitor tracking storage (alternative to Google Tasks/Evernote/OneNote)
# Uses Firestore REST API with service account authentication
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
